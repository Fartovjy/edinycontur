# ──────────────────────────────────────────────────────────────
# Производственный конфиг Единый Контур
# Скопируйте в .env, заполните все значения, НЕ коммитьте .env
# ──────────────────────────────────────────────────────────────

# Сгенерировать ключ:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=ЗАМЕНИТЕ_НА_СЛУЧАЙНУЮ_СТРОКУ_50_СИМВОЛОВ

DJANGO_DEBUG=0

# Через запятую: домен, IP-сервера, localhost для health-check
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Через запятую, с протоколом — нужно для CSRF
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 1 — принудительный редирект на HTTPS (рекомендуется за реальным SSL)
# 0 — если SSL терминируется выше (балансировщик) или SSL ещё не настроен
SECURE_SSL_REDIRECT=1

# PostgreSQL
POSTGRES_DB=ediny_kontur
POSTGRES_USER=ediny_kontur
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_СЛОЖНЫЙ_ПАРОЛЬ

# Публичный URL приложения (без слеша в конце)
WEB_APP_BASE_URL=https://yourdomain.com

# Telegram-бот (оставьте пустым, если не используется)
TELEGRAM_BOT_TOKEN=

# Максимальный размер загружаемого файла, МБ
MAX_UPLOAD_SIZE_MB=10

# Количество воркеров Gunicorn (рекомендуется: 2 × CPU + 1)
GUNICORN_WORKERS=3

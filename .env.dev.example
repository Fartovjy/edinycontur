# Скопируй в .env.dev и заполни POSTGRES_* из .env.prod сервера
# (или запусти dev_start.py — он заполнит автоматически)

DJANGO_SECRET_KEY=dev-only-unsafe-key-not-for-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
SECURE_SSL_REDIRECT=0

# Postgres — через SSH-тоннель (localhost:15433 → сервер:5432)
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=15433
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

WEB_APP_BASE_URL=http://localhost:8000

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=biovetk_bot
MAX_UPLOAD_SIZE_MB=10

EMAIL_HOST=smtp.mail.ru
EMAIL_PORT=465
EMAIL_USE_SSL=1
EMAIL_USE_TLS=0
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
